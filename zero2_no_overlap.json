{
  "train_batch_size": 32,
  "train_micro_batch_size_per_gpu": 2,
  "gradient_accumulation_steps": 4,
  "steps_per_print": 10,

  "_comment": "Experiment A: overlap_comm=false. AllReduce runs SEQUENTIALLY after backward pass. Compare throughput against zero2_overlap_on.json to measure how much latency your interconnect hides.",

  "zero_optimization": {
    "stage": 2,
    "allgather_partitions": true,
    "allgather_bucket_size": 2e8,
    "overlap_comm": false,
    "reduce_scatter": true,
    "reduce_bucket_size": 2e8,
    "contiguous_gradients": true
  },

  "bf16": {
    "enabled": true
  },

  "gradient_clipping": 1.0,

  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": 2e-4,
      "betas": [0.9, 0.95],
      "eps": 1e-8,
      "weight_decay": 0.1
    }
  },

  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "warmup_min_lr": 0,
      "warmup_max_lr": 2e-4,
      "warmup_num_steps": 20,
      "total_num_steps": 300
    }
  },

  "wall_clock_breakdown": true,
  "dump_state": false
}
